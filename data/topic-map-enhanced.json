    "procedureDx": "ProcedureDx/proceduredx-main.html?procedure={procedureId}",
    "teamDx": "TeamDx/teamdx-main.html",
    "systemsDx": "SystemsDx/systemsdx-main.html"
  },
  "epaModules": {
    "description": "New modules addressing previously uncovered EPAs",
    "epa9": {
      "name": "TeamDx - Interprofessional Collaboration",
      "epa": "EPA 9: Collaborate as a member of an interprofessional team",
      "file": "TeamDx/teamdx-main.html",
      "scenarios": [
        "ICU Multidisciplinary Rounds",
        "Rapid Response Teamwork",
        "End-of-Shift Handoff"
      ],
      "skills": [
        "Role respect",
        "Clear communication",
        "Shared decision-making",
        "Situation awareness"
      ]
    },
    "epa11": {
      "name": "ConsentDx - Informed Consent Training",
      "epa": "EPA 11: Obtain informed consent for tests and/or procedures",
      "file": "ConsentDx/consentdx-main.html",
      "scenarios": [
        "Central Line (anxious adult)",
        "Lumbar Puncture (pediatric/parent)",
        "Chest Tube (emergent)",
        "PICC Line (elderly/capacity)",
        "Paracentesis (skeptical)",
        "Family Communication (post-emergency)"
      ],
      "skills": [
        "Plain language communication",
        "Risk/benefit discussion",
        "Capacity assessment",
        "Emergency consent ethics"
      ]
    },
    "epa12": {
      "name": "ProcedureDx - Procedure Preparation Training",
      "epa": "EPA 12: Perform general procedures of a physician",
      "file": "ProcedureDx/proceduredx-main.html",
      "procedures": [
        "Central Line (IJ)",
        "Lumbar Puncture",
        "Chest Tube",
        "Arterial Line"
      ],
      "skills": [
        "Equipment selection",
        "Step sequencing",
        "Complication management",
        "Sterile technique"
      ]
    },
    "epa13": {
      "name": "SystemsDx - Patient Safety & Systems Thinking",
      "epa": "EPA 13: Identify system failures and contribute to a culture of safety",
      "file": "SystemsDx/systemsdx-main.html",
      "modules": [
        "Root Cause Analysis",
        "Swiss Cheese Model",
        "Giving Feedback (Just Culture)",
        "Safety Reporting"
      ],
      "skills": [
        "Systems thinking",
        "RCA methodology",
        "Constructive feedback",
        "Safety culture"
      ]
    }
  },
