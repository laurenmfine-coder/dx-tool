          "missedConsequences": {
            "Neonatal Sepsis": "Mortality 10-20% even with treatment. Untreated progresses to shock, DIC, multi-organ failure within hours.",
            "Meningitis": "30% of neonatal sepsis has meningitis. Delay causes permanent neurologic injury or death.",
            "UTI/Pyelonephritis": "Common source in young infants. If missed, can lead to renal scarring."
          },
          "commonPitfalls": [
            "Trusting a normal temperature - hypothermia or normal temp can occur in sick neonates",
            "Attributing lethargy to 'just tired' or 'fussy baby'",
            "Delaying LP - must be done in febrile infants <60 days",
            "Inadequate fluid resuscitation - use 10-20 mL/kg boluses, reassess frequently",
            "Wrong antibiotic coverage - need ampicillin (Listeria) + cefotaxime or gentamicin"
          ],
          "allDiagnoses": [
            {
              "name": "Neonatal Sepsis",
              "correctCategory": "likely",
              "rationale": "Fever + lethargy + poor feeding + tachycardia + hypotension + prolonged cap refill = sepsis until proven otherwise."
            },
            {
              "name": "Bacterial Meningitis",
              "correctCategory": "must-not-miss",
              "rationale": "30% of neonatal sepsis has concurrent meningitis. LP mandatory unless unstable."
            },
            {
              "name": "Urinary Tract Infection",
              "correctCategory": "must-not-miss",
              "rationale": "Most common source of fever in young infants. Catheterized UA and culture essential."
            },
            {
              "name": "Pneumonia",
              "correctCategory": "must-not-miss",
              "rationale": "Respiratory distress with sepsis - CXR needed. Tachypnea could be primary."
            },
            {
              "name": "Congenital Heart Disease",
              "correctCategory": "must-not-miss",
              "rationale": "Ductal-dependent lesions can present at 2-8 weeks with shock-like picture."
            },
            {
              "name": "Metabolic Disorder",
              "correctCategory": "must-not-miss",
              "rationale": "Inborn errors of metabolism can present with sepsis-like picture. Check glucose, ammonia, lactate."
            },
            {
              "name": "Viral Illness",
              "correctCategory": "less-likely",
              "rationale": "Severity of presentation (hypotension, lethargy) goes beyond typical viral illness."
            }
