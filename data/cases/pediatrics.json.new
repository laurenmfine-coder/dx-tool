          "mcqs": [
            {
              "id": "mcq1",
              "timing": "after-exam",
              "question": "This 8-week-old has fever, lethargy, poor feeding, and signs of shock. What is the MOST important initial intervention?",
              "options": [
                {
                  "text": "Obtain lumbar puncture immediately",
                  "correct": false,
                  "explanation": "LP is important but should NOT delay resuscitation. Stabilize first, then LP if safe."
                },
                {
                  "text": "IV/IO access, 20 mL/kg NS bolus, empiric antibiotics",
                  "correct": true,
                  "explanation": "Septic shock requires immediate vascular access, fluid resuscitation (10-20 mL/kg boluses), and broad-spectrum antibiotics within 1 hour. Per Surviving Sepsis Guidelines."
                },
                {
                  "text": "Wait for blood culture results before starting antibiotics",
                  "correct": false,
                  "explanation": "NEVER delay antibiotics in suspected sepsis. Draw cultures, then give antibiotics immediately."
                },
                {
                  "text": "Transfer to PICU before any interventions",
                  "correct": false,
                  "explanation": "Resuscitation must begin immediately wherever the patient is. Don't delay treatment for transfer."
                }
              ]
            },
            {
              "id": "mcq2",
              "timing": "after-workup",
              "question": "What empiric antibiotic regimen is MOST appropriate for this 8-week-old with suspected sepsis?",
              "options": [
                {
                  "text": "Ceftriaxone alone",
                  "correct": false,
                  "explanation": "Ceftriaxone doesn't cover Listeria monocytogenes, which can cause late-onset neonatal sepsis. Also avoid ceftriaxone in neonates due to bilirubin displacement."
                },
                {
                  "text": "Ampicillin + Cefotaxime (or Gentamicin)",
                  "correct": true,
                  "explanation": "Standard empiric coverage for young infants includes ampicillin (for Listeria and Enterococcus) plus a 3rd gen cephalosporin or aminoglycoside (for GNRs including E. coli). Use cefotaxime not ceftriaxone in neonates."
                },
                {
                  "text": "Vancomycin + Ceftriaxone",
                  "correct": false,
                  "explanation": "Missing Listeria coverage and ceftriaxone should be avoided in neonates."
                },
                {
                  "text": "Amoxicillin oral",
                  "correct": false,
                  "explanation": "Oral antibiotics are never appropriate for suspected neonatal sepsis. IV therapy is mandatory."
                }
              ]
            }
          ]
        }
