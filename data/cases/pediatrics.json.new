          "physicalExam": [
            {
              "id": "general_appearance",
              "text": "General appearance",
              "category": "General",
              "finding": "Lethargic, pale infant. Opens eyes to stimulation but not tracking. Weak cry. Decreased spontaneous movement.",
              "tier": "essential",
              "linkedDx": ["Sepsis", "Meningitis"],
              "reasoning": "Altered mental status in infant is critical finding"
            },
            {
              "id": "vitals",
              "text": "Review vital signs",
              "category": "Vitals",
              "finding": "HR 195 (high), RR 68 (high), Temp 38.2°C rectal, BP 58/35 (low), SpO2 92% RA. Cap refill 4 seconds centrally.",
              "tier": "essential",
              "linkedDx": ["Septic Shock"],
              "reasoning": "Tachycardia, hypotension, prolonged cap refill = shock"
            },
            {
              "id": "skin",
              "text": "Examine skin",
              "category": "Skin",
              "finding": "Pale, mottled appearance on extremities. No petechiae or purpura. No rashes.",
              "tier": "essential",
              "linkedDx": ["Shock", "Meningococcemia"],
              "reasoning": "Mottling indicates poor perfusion; no petechiae reassuring against meningococcemia"
            },
            {
              "id": "fontanelle",
              "text": "Examine fontanelle",
              "category": "Head",
              "finding": "Anterior fontanelle is soft and flat, not bulging.",
              "tier": "essential",
              "linkedDx": ["Meningitis", "Dehydration"],
              "reasoning": "Bulging fontanelle would suggest increased ICP; sunken would indicate dehydration"
            },
            {
              "id": "lungs",
              "text": "Auscultate lungs",
              "category": "Respiratory",
              "finding": "Tachypneic with mild subcostal retractions. Clear breath sounds bilaterally, good air entry.",
              "tier": "essential",
              "linkedDx": ["Pneumonia", "Metabolic acidosis"],
              "reasoning": "Tachypnea may be compensatory for metabolic acidosis"
            },
            {
              "id": "cardiac",
              "text": "Cardiac exam",
              "category": "Cardiovascular",
              "finding": "Tachycardic, regular rhythm. No murmur. Weak peripheral pulses, slightly stronger central pulses.",
              "tier": "essential",
              "linkedDx": ["Shock", "CHD"],
              "reasoning": "Pulse differential suggests compensated shock; no murmur makes CHD less likely"
            },
            {
              "id": "abdomen",
              "text": "Examine abdomen",
              "category": "GI",
              "finding": "Soft, non-distended. No hepatosplenomegaly. Umbilicus clean, healed.",
