    {
      "id": "pediatric-sepsis",
      "title": "Lethargic Infant with Fever",
      "category": "Pediatrics/Emergency",
      "subcategory": "Critical Care",
      "icon": "🚨",
      "difficulty": "advanced",
      "urgency": "emergent",
      "guidelineReferences": [
        {
          "name": "Surviving Sepsis Campaign International Guidelines for Pediatric Sepsis 2020",
          "citation": "Weiss SL, et al. Pediatr Crit Care Med. 2020;21(2):e52-e106",
          "keyPoints": [
            "Recognize sepsis using systematic screening - SIRS criteria may miss sepsis in children",
            "For septic shock: IV/IO access within 5 min, fluid resuscitation within 30 min, broad-spectrum antibiotics within 1 hour",
            "Initial fluid bolus 10-20 mL/kg over 5-20 min, assess after each bolus",
            "Epinephrine or norepinephrine for fluid-refractory shock",
            "Target MAP normal for age (not adult targets)",
            "Consider stress-dose hydrocortisone for catecholamine-resistant shock"
          ],
          "url": "https://journals.lww.com/pccmjournal/fulltext/2020/02000/surviving_sepsis_campaign_international.3.aspx"
        },
        {
          "name": "Phoenix Sepsis Criteria 2024",
          "citation": "Schlapbach LJ, et al. JAMA. 2024;331(8):665-674",
          "keyPoints": [
            "New pediatric sepsis criteria validated across 10 countries",
            "Phoenix Sepsis Score: Respiratory (0-3) + Cardiovascular (0-6) + Coagulation (0-2) + Neurologic (0-2)",
            "Sepsis = infection + Phoenix score ≥2",
            "More specific than SIRS, identifies high-risk children"
          ]
        }
      ],
