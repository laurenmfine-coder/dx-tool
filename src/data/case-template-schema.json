{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReasonDx Case Template",
  "description": "Schema for clinical case templates with AI patient guidance",
  "type": "object",
  "required": ["id", "presentation", "category", "variants"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the presentation (e.g., 'chest-pain')"
    },
    "presentation": {
      "type": "string",
      "description": "Human-readable name (e.g., 'Chest Pain')"
    },
    "category": {
      "type": "string",
      "enum": ["cardiovascular", "pulmonary", "gastrointestinal", "neurologic", "musculoskeletal", "infectious", "psychiatric", "obstetric", "pediatric", "other"]
    },
    "difficulty": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "1=straightforward, 5=complex/rare"
    },
    "rotations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["em", "medicine", "surgery", "obgyn", "psychiatry", "pediatrics"]
      },
      "description": "Which rotations see this presentation"
    },
    "demographics": {
      "type": "object",
      "properties": {
        "ageRange": {
          "type": "array",
          "items": { "type": "integer" },
          "minItems": 2,
          "maxItems": 2
        },
        "genderDistribution": {
          "type": "object",
          "properties": {
            "male": { "type": "number" },
            "female": { "type": "number" }
          }
        },
        "nameOptions": {
          "type": "object",
          "properties": {
            "male": { "type": "array", "items": { "type": "string" } },
            "female": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "variants": {
      "type": "array",
      "items": { "$ref": "#/definitions/Variant" },
      "minItems": 1,
      "description": "Different diagnostic outcomes for same presentation"
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/definitions/Source" },
      "description": "Peer-reviewed sources for clinical content"
    }
  },
  "definitions": {
    "Variant": {
      "type": "object",
      "required": ["id", "diagnosis", "clinicalFacts", "patient"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique variant ID (e.g., 'stemi-v1')"
        },
        "diagnosis": {
          "type": "string",
          "description": "Final diagnosis for this variant"
        },
        "acuity": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "ESI acuity level"
        },
        "patient": { "$ref": "#/definitions/PatientPersona" },
        "clinicalFacts": { "$ref": "#/definitions/ClinicalFacts" },
        "physicalExam": { "$ref": "#/definitions/PhysicalExam" },
        "diagnostics": { "$ref": "#/definitions/Diagnostics" },
        "evolution": { "$ref": "#/definitions/Evolution" },
        "teaching": { "$ref": "#/definitions/Teaching" }
      }
    },
    "PatientPersona": {
      "type": "object",
      "properties": {
        "personalityTraits": {
          "type": "array",
          "items": { "type": "string" },
          "description": "e.g., ['anxious', 'cooperative', 'stoic']"
        },
        "communicationStyle": {
          "type": "string",
          "description": "How patient communicates"
        },
        "emotionalState": {
          "type": "string",
          "description": "Current emotional presentation"
        },
        "medicalLiteracy": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "languageNotes": {
          "type": "string",
          "description": "e.g., 'English second language, Spanish native'"
        },
        "occupation": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Possible occupations"
        }
      }
    },
    "ClinicalFacts": {
      "type": "object",
      "description": "Evidence-based clinical content for AI grounding",
      "properties": {
        "chiefComplaint": {
          "type": "object",
          "properties": {
            "patientPhrasing": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Words patient uses (e.g., ['tight', 'pressure', 'heavy'])"
            },
            "avoidPhrasing": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Words to avoid (suggest other Dx)"
            },
            "location": { "type": "string" },
            "radiation": {
              "type": "array",
              "items": { "type": "string" }
            },
            "onset": { "type": "string" },
            "duration": { "type": "string" },
            "severity": { "type": "string" },
            "timing": { "type": "string" },
            "aggravating": {
              "type": "array",
              "items": { "type": "string" }
            },
            "relieving": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "associatedSymptoms": {
          "type": "object",
          "properties": {
            "present": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Symptoms to confirm if asked"
            },
            "absent": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Pertinent negatives to deny if asked"
            }
          }
        },
        "pmh": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Past medical history"
        },
        "medications": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "dose": { "type": "string" },
              "compliance": { "type": "string" }
            }
          }
        },
        "allergies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "allergen": { "type": "string" },
              "reaction": { "type": "string" }
            }
          }
        },
        "socialHistory": {
          "type": "object",
          "properties": {
            "smoking": { "type": "string" },
            "alcohol": { "type": "string" },
            "drugs": { "type": "string" },
            "occupation": { "type": "string" },
            "livingSituation": { "type": "string" }
          }
        },
        "familyHistory": {
          "type": "array",
          "items": { "type": "string" }
        },
        "riskFactors": {
          "type": "object",
          "properties": {
            "present": { "type": "array", "items": { "type": "string" } },
            "absent": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "PhysicalExam": {
      "type": "object",
      "properties": {
        "vitalSigns": {
          "type": "object",
          "properties": {
            "BP": { "type": "string" },
            "HR": { "type": "string" },
            "RR": { "type": "string" },
            "Temp": { "type": "string" },
            "SpO2": { "type": "string" }
          }
        },
        "general": { "type": "string" },
        "heent": { "type": "string" },
        "neck": { "type": "string" },
        "cardiovascular": { "type": "string" },
        "pulmonary": { "type": "string" },
        "abdominal": { "type": "string" },
        "extremities": { "type": "string" },
        "neurologic": { "type": "string" },
        "skin": { "type": "string" },
        "psychiatric": { "type": "string" }
      }
    },
    "Diagnostics": {
      "type": "object",
      "properties": {
        "labs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "test": { "type": "string" },
              "value": { "type": "string" },
              "unit": { "type": "string" },
              "reference": { "type": "string" },
              "status": { "type": "string", "enum": ["normal", "abnormal", "critical"] },
              "interpretation": { "type": "string" }
            }
          }
        },
        "imaging": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "study": { "type": "string" },
              "findings": { "type": "string" },
              "impression": { "type": "string" },
              "critical": { "type": "boolean" }
            }
          }
        },
        "ecg": {
          "type": "object",
          "properties": {
            "findings": { "type": "array", "items": { "type": "string" } },
            "interpretation": { "type": "string" }
          }
        }
      }
    },
    "Evolution": {
      "type": "object",
      "description": "How patient changes over time",
      "properties": {
        "onCorrectTreatment": {
          "type": "object",
          "properties": {
            "vitalsTrend": { "type": "string" },
            "symptomsTrend": { "type": "string" },
            "labsTrend": { "type": "string" },
            "narrative": { "type": "string" }
          }
        },
        "onDelayedTreatment": {
          "type": "object",
          "properties": {
            "vitalsTrend": { "type": "string" },
            "complications": { "type": "array", "items": { "type": "string" } },
            "narrative": { "type": "string" }
          }
        },
        "onNoTreatment": {
          "type": "object",
          "properties": {
            "deteriorationRate": { "type": "string" },
            "triggerRapidResponse": { "type": "boolean" },
            "narrative": { "type": "string" }
          }
        }
      }
    },
    "Teaching": {
      "type": "object",
      "properties": {
        "keyLearningPoints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mustNotMiss": {
          "type": "array",
          "items": { "type": "string" }
        },
        "commonPitfalls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expertApproach": {
          "type": "object",
          "properties": {
            "differentialWithProbabilities": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "diagnosis": { "type": "string" },
                  "probability": { "type": "number" },
                  "reasoning": { "type": "string" }
                }
              }
            },
            "keyQuestions": { "type": "array", "items": { "type": "string" } },
            "reasoning": { "type": "string" }
          }
        },
        "teachingHooks": {
          "type": "object",
          "description": "Conditional hints based on student actions",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "Source": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["statpearls", "pubmed", "guideline", "ncbi-bookshelf"] },
        "url": { "type": "string" },
        "pmcid": { "type": "string" },
        "accessDate": { "type": "string" },
        "citedFor": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
